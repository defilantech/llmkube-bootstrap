{
  "$schema": "https://opencode.ai/config.json",
  "_comment": "Generated by llmkube-bootstrap. Edit freely. Secrets ride via {env:VAR}; never check them in.",
  "provider": {
    "llmkube-local": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server: starter model (phi-4-mini-instruct, Q4_K_M)",
      "options": {
        "baseURL": "http://localhost:8080/v1",
        "apiKey": "local"
      },
      "models": {
        "phi-4-mini": {
          "name": "phi-4-mini-instruct (llama-server, Metal)",
          "limit": {
            "context": 8192,
            "output": 4096
          }
        }
      }
    }
  },
  "model": "llmkube-local/phi-4-mini",
  "mcp": {
    "brave-search": {
      "type": "local",
      "command": ["npx", "-y", "@brave/brave-search-mcp-server"],
      "enabled": true,
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      },
      "timeout": 15000
    },
    "github": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-github"],
      "enabled": true,
      "environment": {},
      "timeout": 15000
    },
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp@latest"],
      "enabled": true,
      "timeout": 15000
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp@latest"],
      "enabled": true,
      "timeout": 15000
    },
    "huggingface": {
      "type": "remote",
      "url": "https://huggingface.co/mcp",
      "enabled": true,
      "headers": {
        "Authorization": "Bearer {env:HF_TOKEN}"
      },
      "timeout": 15000
    }
  },
  "tools": {
    "brave-search*": false,
    "playwright*": false,
    "huggingface*": false
  },
  "agent": {
    "plan": {
      "model": "llmkube-local/phi-4-mini",
      "temperature": 0.6,
      "steps": 40,
      "description": "Architect: reasons about the change, proposes a plan, never edits files. Switch this `model` line to point at a larger model (e.g. carnice) once you have one deployed.",
      "tools": {
        "brave-search*": true
      }
    },
    "build": {
      "model": "llmkube-local/phi-4-mini",
      "temperature": 0.2,
      "steps": 80,
      "description": "Editor: applies the architect's plan via tool calls."
    },
    "review": {
      "mode": "subagent",
      "model": "llmkube-local/phi-4-mini",
      "temperature": 0.3,
      "steps": 30,
      "description": "Reviews changes for correctness, missing tests, and edge cases.",
      "permission": {
        "edit": "deny",
        "bash": "ask"
      },
      "tools": {
        "brave-search*": true
      }
    }
  }
}
